# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Required by pipeline/brainstorm/brainstorm.js and pipeline/build/build-daily.js
ANTHROPIC_API_KEY=sk-ant-...

# Required by site at build time. After you run `npx partykit deploy` from /partykit,
# put the resulting host here (e.g. plus1games.your-username.partykit.dev).
# For local dev, leave empty — site will fall back to 127.0.0.1:1999.
VITE_PARTYKIT_HOST=
